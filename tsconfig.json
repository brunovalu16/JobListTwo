{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@assets/*": ["./src/assets/*"],
      "@components/*": ["./src/components/*"],
      "@routes/*": ["./src/routes/*"],
      "@screens/*": ["./src/screens/*"],
      "@stores/*": ["./src/stores/*"],
      "@theme/*": ["./src/theme/*"], // Verifique se está assim
      "@utils/*": ["./src/utils/*"],
      "@Highlight/*": ["./src/Highlight/*"],
    }
  }
}
